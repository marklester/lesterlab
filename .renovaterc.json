{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "kubernetes": {
    "fileMatch": [
      "kubernetes/argocd/main-cluster/manifests/tunarr/tunarr\\.deployment\\.yaml",
      "kubernetes/argocd/main-cluster/manifests/bazarr/deployment\\.yml",
      "kubernetes/argocd/main-cluster/manifests/bitwarden/bitwarden\\.deployment\\.yaml",
      "kubernetes/argocd/main-cluster/manifests/jackett/jackett\\.deployment\\.yaml",
      "kubernetes/argocd/main-cluster/manifests/plex/plex\\.deployment\\.yaml"
    ]
  },
  "argocd": {
    "managerFilePatterns": ["/kubernetes/argocd/.+\\.app\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/chrisbenincasa/tunarr"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/manifests/tunarr/tunarr\\.deployment\\.yaml"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "tunarr image"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/linuxserver/bazarr", "linuxserver/bazarr", "lscr.io/linuxserver/bazarr"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/manifests/bazarr/deployment\\.yml"],
      "versioning": "docker",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "bazarr image"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["vaultwarden/server"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/manifests/bitwarden/bitwarden\\.deployment\\.yaml"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "bitwarden image"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["linuxserver/jackett", "lscr.io/linuxserver/jackett"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/manifests/jackett/jackett\\.deployment\\.yaml"],
      "versioning": "docker",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "jackett image"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["linuxserver/plex"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/manifests/plex/plex\\.deployment\\.yaml"],
      "versioning": "docker",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "plex image"
    },
    {
      "matchDatasources": ["helm"],
      "matchPackageNames": ["traefik"],
      "matchFileNames": ["kubernetes/argocd/main-cluster/apps/traefik\\.app\\.yaml"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "traefik chart"
    },
    {
      "matchDatasources": ["helm"],
      "matchPackageNames": ["local-path-provisioner"],
      "matchFileNames": ["kubernetes/argocd/moonbase/apps/localpath-provisioner\\.app\\.yaml"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "local-path-provisioner chart"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["garethgeorge/backrest"],
      "matchFileNames": ["kubernetes/argocd/moonbase/manifests/backrest/backrest\\.deployment\\.yaml"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["renovate", "dependencies"],
      "commitMessageTopic": "backrest image"
    }
  ]
}